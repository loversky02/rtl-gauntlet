# RTL-Gauntlet model gateway — OpenAI-compatible. Copy to `.env` and fill the key.
# rtl_gauntlet/llm.py auto-loads `.env` from the repo root (no `source` needed).
# `.env` is git-ignored; this `.env.example` is the committed template.

# ===== DeepSeek (direct provider — "V4 Pro") =====
RTLG_BASE_URL=https://api.deepseek.com
RTLG_API_KEY=
RTLG_MODEL=deepseek-chat          # confirm the exact "V4 Pro" id at https://api-docs.deepseek.com

# ===== Gemini (direct provider — Google AI Studio, OpenAI-compatible) — MODEL #5 scaffold =====
# Fill RTLG_API_KEY with a Google AI Studio key (https://aistudio.google.com/apikey), then:
#   RTLG_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/ \
#   RTLG_MODEL=gemini-2.5-pro \
#   python3 scripts/run_veval.py --workdir runs/veval_gemini --out results/sweep_gemini.json
# llm.py retries with backoff, so a flaky gateway won't corrupt the sweep (cf. gpt-5.5).
# RTLG_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# RTLG_API_KEY=                     # <-- Google AI Studio key (real money; billed per token)
# RTLG_MODEL=gemini-2.5-pro         # or gemini-2.5-flash (cheaper)

# ===== Alt: self-hosted 9router gateway (Opus/Haiku routed ~free) =====
# RTLG_BASE_URL=http://localhost:9router/v1
# RTLG_API_KEY=sk-...
# RTLG_MODEL=cc/claude-opus-4-8

# ===== Alt: any OpenAI-compatible endpoint (llm.py also honors OPENAI_*) =====
# OPENAI_BASE_URL=...
# OPENAI_API_KEY=...
