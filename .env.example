# RTL-Gauntlet model gateway — OpenAI-compatible. Copy to `.env` and fill the key.
# rtl_gauntlet/llm.py auto-loads `.env` from the repo root (no `source` needed).
# `.env` is git-ignored; this `.env.example` is the committed template.

# ===== DeepSeek (direct provider — "V4 Pro") =====
RTLG_BASE_URL=https://api.deepseek.com
RTLG_API_KEY=
RTLG_MODEL=deepseek-chat          # confirm the exact "V4 Pro" id at https://api-docs.deepseek.com

# ===== Alt: self-hosted 9router gateway (Opus/Haiku routed ~free) =====
# RTLG_BASE_URL=http://localhost:9router/v1
# RTLG_API_KEY=sk-...
# RTLG_MODEL=cc/claude-opus-4-8

# ===== Alt: any OpenAI-compatible endpoint (llm.py also honors OPENAI_*) =====
# OPENAI_BASE_URL=...
# OPENAI_API_KEY=...
